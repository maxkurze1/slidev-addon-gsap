# Cheat sheet

```ts
import { useTl, usePos, useTwo, useSlide } from "slidev-addon-gsap"

const tl  = useTl()        // paused, click-driven GSAP timeline
const pos = usePos()       // reactive DOM anchors
const two = useTwo()       // Two.js front/back drawing layers

// — timeline — clicks are inferred from step() count
tl.step().from(".x", { opacity: 0 }).step().to(".x", { x: 100 }).step()
tl.step().morph(".a", ".b").step()   // A fits onto B + cross-fades (magic-move)

// — preset effects — chainable, good defaults; override with GSAP vars
tl.step().popIn(".a").step().slideIn(".b", { from: "left" }).step().pulse(".b").step()
//   in: fadeIn popIn scaleIn slideIn flyIn blurIn dropIn · out: *Out · emphasis: pulse shake wiggle flash bounce

// — cross-slide morph — fully automatic (no setup); any transition
//   same data-morph="key" on adjacent slides → <div data-morph="hero"/> flies between them
//   tune via frontmatter:  morph: { duration: 1.1, ease: power2.inOut }   (deck or per-slide)

// — code magic-move — Slidev's magic-move block shares the click axis with useTl
//   place it with an absolute {at: N} so code morphs line up with your tl steps

// — positions — "selector@anchor"
//   axis-aligned: c t b l r tl tr bl br   ·   rotation-aware: n s e w ne nw se sw
